{
  "main": "electron.js",
  "scripts": {
    "serve": "vite",
    "build": "vite build",
    "electron:serve": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.iskportal.mithra",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "preload.js"
    ],
    "extraResources": {
      "from": "./public/",
      "to": "./public/"
    }
  }
}